# LLM Provider — choose one
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chroma
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_rbac_docs

# JWT  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-me-in-production-use-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# API
API_HOST=0.0.0.0
API_PORT=8000

# Retrieval
RETRIEVAL_K=5

# Cost alerts (USD)
COST_ALERT_PER_REQUEST=0.10
COST_ALERT_PER_USER_DAILY=5.00
COST_ALERT_SYSTEM_DAILY=50.00
